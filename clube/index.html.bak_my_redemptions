<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Clube Premium</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="styles.css" />
</head>
<body>
  <div class="club-shell">
    <aside class="club-sidebar">
      <div class="club-brand">
        <div class="club-logo">CP</div>
        <div>
          <h1>Clube Premium</h1>
          <p>Dra. Alessandra</p>
        </div>
      </div>

      <div class="club-profile-card">
        <div class="muted">Olá,</div>
        <div class="club-user-name" id="sidebar-user-name">Maria Silva</div>
        <hr>
        <div class="club-mini-row">
          <span>Pontos</span>
          <strong id="sidebar-user-points">2.350</strong>
        </div>
        <div class="club-mini-row">
          <span>Nível</span>
          <strong id="sidebar-user-level">Ouro</strong>
        </div>
      </div>

      <nav class="club-nav">
        <button class="club-nav-link active" data-page="inicio"><i class="fa-solid fa-table-cells-large"></i><span>Início</span></button>
        <button class="club-nav-link" data-page="premios"><i class="fa-solid fa-gift"></i><span>Prêmios</span></button>
        <button class="club-nav-link" data-page="parceiros"><i class="fa-solid fa-store"></i><span>Parceiros</span></button>
        <button class="club-nav-link" data-page="indicacoes"><i class="fa-solid fa-user-group"></i><span>Indicações</span></button>
        <button class="club-nav-link" data-page="historico"><i class="fa-solid fa-clock-rotate-left"></i><span>Histórico</span></button>
      </nav>

      <div class="club-sidebar-footer">
        <div class="sidebar-admin-row">
          <span><i class="fa-regular fa-user mr-2"></i> <span id="sidebar-user-role">Paciente</span></span>
        </div>
        <button class="btn-light full" id="club-logout-btn"><i class="fa-solid fa-power-off"></i> Sair</button>
      </div>
    </aside>

    <main class="club-main">
      <header class="club-topbar">
        <div></div>
        <button class="notification-btn">
          <i class="fa-regular fa-bell"></i>
          <span class="notification-badge">4</span>
        </button>
      </header>

      <section class="club-page active" id="page-inicio">
        <div class="hero-card">
          <div class="hero-badge">Ouro</div>
          <div class="hero-welcome">Bem-vinda,</div>
          <h2 id="hero-user-name">Maria Silva</h2>
          <div class="hero-points"><span id="hero-user-points">2.350</span> <small>pontos</small></div>
          <div class="hero-sub">4.500 pontos acumulados no total</div>

          <div class="hero-progress-header">
            <span>Progresso para Diamante</span>
            <strong>50%</strong>
          </div>
          <div class="progress-bar">
            <div class="progress-fill" style="width: 50%"></div>
          </div>
          <div class="hero-foot">Faltam 1.500 pontos</div>
        </div>

        <div class="grid-2">
          <div class="feature-card">
            <div class="feature-icon"><i class="fa-solid fa-gift"></i></div>
            <h3>Resgatar Prêmios</h3>
            <p>Troque seus pontos</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon"><i class="fa-solid fa-user-group"></i></div>
            <h3>Indicar Amigos</h3>
            <p>Ganhe mais pontos</p>
          </div>
        </div>

        <div class="panel-card">
          <div class="section-head">
            <h3><i class="fa-solid fa-sparkles"></i> Como Ganhar Pontos</h3>
          </div>
          <div class="points-list">
            <div class="points-item">
              <div class="points-badge">50</div>
              <div>Consulta realizada</div>
            </div>
            <div class="points-item">
              <div class="points-badge">150</div>
              <div>Procedimento estético</div>
            </div>
            <div class="points-item">
              <div class="points-badge">300</div>
              <div>Plano mensal fechado</div>
            </div>
          </div>
        </div>
      </section>

      <section class="club-page" id="page-premios">
        <div class="title-banner">
          <h2><i class="fa-solid fa-gift"></i> Resgatar Prêmios</h2>
          <p>Você tem <strong>2.350 pontos</strong> disponíveis</p>
        </div>

        <div class="cards-grid">
          <article class="reward-card">
            <div class="reward-image placeholder-bg-1"></div>
            <div class="reward-body">
              <h3>R$ 50 de Desconto</h3>
              <p>Desconto de R$ 50 em qualquer tratamento</p>
              <div class="reward-price">500 pontos</div>
              <button class="btn-primary full">Resgatar Agora</button>
            </div>
          </article>

          <article class="reward-card">
            <div class="reward-image placeholder-bg-2"></div>
            <div class="reward-body">
              <h3>Limpeza de Pele Grátis</h3>
              <p>Uma sessão completa de limpeza de pele</p>
              <div class="reward-price">1.500 pontos</div>
              <button class="btn-primary full">Resgatar Agora</button>
            </div>
          </article>

          <article class="reward-card">
            <div class="reward-image placeholder-bg-3"></div>
            <div class="reward-body">
              <h3>R$ 100 de Desconto</h3>
              <p>Desconto em tratamentos acima de R$ 500</p>
              <div class="reward-price">900 pontos</div>
              <button class="btn-primary full">Resgatar Agora</button>
            </div>
          </article>
        </div>
      </section>

      <section class="club-page" id="page-parceiros">
        <div class="title-banner">
          <h2><i class="fa-solid fa-store"></i> Parceiros Exclusivos</h2>
          <p>Descontos e benefícios em estabelecimentos selecionados</p>
        </div>

        <div class="partner-grid">
          <article class="partner-card">
            <h3>Academia FitLife</h3>
            <p>20% de desconto na matrícula</p>
          </article>
          <article class="partner-card">
            <h3>Farmácia Vida Saudável</h3>
            <p>15% em todos os produtos</p>
          </article>
          <article class="partner-card">
            <h3>NutriVida Consultoria</h3>
            <p>Primeira consulta grátis</p>
          </article>
          <article class="partner-card">
            <h3>Loja Organic Beauty</h3>
            <p>15% em toda a loja</p>
          </article>
        </div>
      </section>

      <section class="club-page" id="page-indicacoes">
        <div class="title-banner">
          <h2><i class="fa-solid fa-user-group"></i> Indicar Amigos</h2>
          <p>Convide amigos e ganhe pontos quando eles se tornarem clientes</p>
        </div>

        <div class="stats-grid">
          <div class="stat-card"><span>Total de Indicações</span><strong>3</strong></div>
          <div class="stat-card"><span>Conversões</span><strong>1</strong></div>
          <div class="stat-card"><span>Pontos Ganhos</span><strong>600</strong></div>
        </div>

        <div class="panel-card">
          <div class="section-head">
            <h3>Seu Código de Convite</h3>
            <p>Compartilhe seu código exclusivo</p>
          </div>
          <div class="invite-code">MARIA2024</div>
          <div class="button-row">
            <button class="btn-primary flex-1">Compartilhar</button>
            <button class="btn-light flex-1">Gerar QR Code</button>
          </div>
        </div>
      </section>

      <section class="club-page" id="page-historico">
        <div class="title-banner">
          <h2><i class="fa-solid fa-clock-rotate-left"></i> Histórico de Pontos</h2>
          <p>Acompanhe todas as suas movimentações</p>
        </div>

        <div class="stats-grid">
          <div class="stat-card positive"><span>Total Ganho</span><strong>+1.100</strong></div>
          <div class="stat-card negative"><span>Total Gasto</span><strong>-500</strong></div>
        </div>

        <div class="panel-card">
          <div class="history-list">
            <div class="history-item">
              <div>
                <h4>Plano Mensal Premium - Março 2026</h4>
                <p>15 de mar. de 2026, 10:30</p>
              </div>
              <strong class="positive-text">+300</strong>
            </div>
            <div class="history-item">
              <div>
                <h4>Indicação convertida - Ana Paula</h4>
                <p>10 de mar. de 2026, 14:20</p>
              </div>
              <strong class="positive-text">+500</strong>
            </div>
            <div class="history-item">
              <div>
                <h4>Resgate: Sessão de Limpeza de Pele</h4>
                <p>08 de mar. de 2026, 16:00</p>
              </div>
              <strong class="negative-text">-500</strong>
            </div>
          </div>
        </div>
      </section>
    </main>
  </div>

  <script src="app.js"></script>
</body>
</html>

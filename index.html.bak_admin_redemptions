<html lang="pt-BR">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width,initial-scale=1" name="viewport"/>
<title>MediCore - Sistema Clínico</title>
<!-- Bibliotecas -->
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet"/>
<link href="style.css" rel="stylesheet"/>
</head>
<body>
<!-- LOGIN MODAL -->
<div class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 backdrop-blur-sm" id="modal-login" style="background-color: rgba(111,75,54,0.2);">
    <div class="bg-white p-8 rounded-3xl shadow-2xl w-96 text-center" style="border: 1px solid rgba(203,229,247,0.3);">
        <div class="w-20 h-20 bg-[#6F4B36] rounded-2xl mx-auto mb-4 flex items-center justify-center">
            <i class="fa-solid fa-stethoscope text-4xl text-white"></i>
        </div>
        <h2 class="font-heading text-3xl font-bold text-[#6F4B36] mb-2">MediCore</h2>
        <p class="text-sm text-gray-500 mb-6 font-body">Sistema Integrado de Gestão Clínica</p>
<div class="login-form-fields">
    <input type="email" id="login-email" placeholder="Email" class="login-input">
    <input type="password" id="login-senha" placeholder="Senha" class="login-input">
    <button type="button" id="login-submit" onclick="login()" class="login-submit-btn">Entrar</button>
</div>
    </div>
</div>

<!-- TOAST NOTIFICATION -->
<div class="hidden fixed bottom-6 right-6 bg-[#6F4B36] text-white px-6 py-4 rounded-2xl shadow-xl z-50 toast-animate" id="toast-notification" style="border: 1px solid rgba(255,255,255,0.1);">
    <i class="fa-solid fa-circle-check mr-2"></i>
    <span>Sucesso</span>
</div>

<!-- APP SHELL -->
<div class="app-shell">
    <aside class="sidebar no-print">
        <div class="sidebar-brand">
            <div class="brand-logo-wrap">
                <img src="logo.png" alt="Logo da clínica" class="brand-logo" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"/>
                <div class="brand-logo-fallback">
                    <i class="fa-solid fa-heart-pulse"></i>
                </div>
            </div>
            <div class="brand-text">
                <h1 class="font-heading">MediCore AI</h1>
                <div class="badge badge-secondary text-xs" id="user-role-badge">Aguardando login...</div>
            </div>
        </div>

                <nav class="sidebar-nav">
            <button class="nav-link" onclick="showSection('dashboard')"><i class="fa-solid fa-chart-line"></i><span>Dashboard</span></button>
            <button class="nav-link" onclick="showSection('estrategia')"><i class="fa-solid fa-chart-area"></i><span>Estratégia</span></button>
            <button class="nav-link" onclick="showSection('protocolos')"><i class="fa-solid fa-clipboard-list"></i><span>Protocolos</span></button>
            <button class="nav-link" onclick="showSection('pacientes')"><i class="fa-solid fa-users"></i><span>Pacientes</span></button>
            <button class="nav-link" onclick="showSection('agenda')"><i class="fa-regular fa-calendar-days"></i><span>Agenda</span></button>
            <button class="nav-link" onclick="showSection('atendimento')"><i class="fa-solid fa-stethoscope"></i><span>Atendimento</span></button>
            <button class="nav-link" onclick="showSection('estoque')"><i class="fa-solid fa-boxes-stacked"></i><span>Estoque</span></button>
            <button class="nav-link" onclick="showSection('financeiro')"><i class="fa-solid fa-wallet"></i><span>Financeiro</span></button>
            <button class="nav-link hidden" id="nav-cupons-btn" onclick="showSection('cupons')"><i class="fa-solid fa-ticket"></i><span>Cupons</span></button>
            <button class="nav-link" id="nav-recompensas-btn" onclick="showSection('recompensas-admin')"><i class="fa-solid fa-gift"></i><span>Recompensas</span></button>
            <button class="nav-link" onclick="showSection('relatorios')"><i class="fa-solid fa-file-invoice"></i><span>Relatórios</span></button>
            <button class="nav-link" onclick="showSection('auditoria')"><i class="fa-solid fa-clipboard-check"></i><span>Auditoria</span></button>
        </nav>

        <div class="sidebar-footer">
            <div class="sidebar-user-card">
                <div class="flex items-center justify-between gap-3">
                    <span class="font-body text-sm text-gray-600" id="header-username">
                        <i class="fa-regular fa-user mr-2"></i>Usuário
                    </span>
                    <div class="hidden bg-[#6F4B36] text-white rounded-full w-7 h-7 flex items-center justify-center text-xs font-bold cursor-pointer" id="alert-badge" onclick="showSection('dashboard');" title="Alertas de Estoque">
                        <span>0</span>
                    </div>
                </div>
                <button class="btn-secondary sidebar-logout" onclick="logout()">
                    <i class="fa-solid fa-power-off mr-2"></i>Sair
                </button>
            </div>
        </div>
    </aside>

    <div class="app-content">
        <header class="content-header">
            <div>
                <p class="content-eyebrow">Sistema Integrado de Gestão Clínica</p>
                <h2 class="section-title mb-0" id="page-title">Visão Geral</h2>
            </div>
        </header>

        <main class="layout-container content-main py-8">
    <!-- DASHBOARD -->

    <section id="dashboard" class="gap-section">
        <!-- Alertas de Estoque -->
        <div class="hidden alert-box mb-8" id="dashboard-alerts">
            <div class="flex items-center gap-3 mb-3">
                <div class="w-8 h-8 bg-[#6F4B36] rounded-full flex items-center justify-center">
                    <i class="fa-solid fa-circle-exclamation text-white text-sm"></i>
                </div>
                <h3 class="font-heading font-bold text-[#6F4B36]">Alertas de Estoque</h3>
            </div>
            <div class="space-y-2 text-sm text-gray-700" id="alerts-list"></div>
        </div>

        <!-- KPI Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
            <div class="kpi-card">
                <div class="flex justify-between items-start mb-2">
                    <div class="kpi-label">Total Pacientes</div>
                    <div class="w-10 h-10 bg-[#CBE5F7] rounded-xl flex items-center justify-center">
                        <i class="fa-solid fa-users text-[#6F4B36] text-lg"></i>
                    </div>
                </div>
                <div class="kpi-value" id="kpi-total-patients">0</div>
            </div>
            <div class="kpi-card">
                <div class="flex justify-between items-start mb-2">
                    <div class="kpi-label">Agendamentos Hoje</div>
                    <div class="w-10 h-10 bg-[#CBE5F7] rounded-xl flex items-center justify-center">
                        <i class="fa-regular fa-calendar-check text-[#6F4B36] text-lg"></i>
                    </div>
                </div>
                <div class="kpi-value" id="kpi-today-appts">0</div>
            </div>
            <div class="kpi-card">
                <div class="flex justify-between items-start mb-2">
                    <div class="kpi-label">Faturamento Total</div>
                    <div class="w-10 h-10 bg-[#CBE5F7] rounded-xl flex items-center justify-center">
                        <i class="fa-solid fa-chart-pie text-[#6F4B36] text-lg"></i>
                    </div>
                </div>
                <div class="kpi-value" id="kpi-sales">R$ 0,00</div>
            </div>
        </div>

        <!-- Oportunidades de Retorno -->
        <div class="card p-6">
            <div class="flex justify-between items-center mb-6">
                <div>
                    <h3 class="font-heading font-bold text-lg text-[#6F4B36] flex items-center gap-2">
                        <i class="fa-solid fa-clock-rotate-left"></i>
                        Oportunidades de Retorno
                    </h3>
                    <p class="font-body text-sm text-gray-500">Pacientes inativos há mais de 3 meses</p>
                </div>
                <span class="badge badge-primary" id="inactive-count">0 encontrados</span>
            </div>
            <div class="max-h-64 overflow-y-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr>
                            <th class="text-left">Paciente</th>
                            <th class="text-left">Telefone</th>
                            <th class="text-left">Última Visita</th>
                            <th class="text-center">Dias Inativo</th>
                            <th class="text-center">Ação</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-[#CBE5F7] divide-opacity-30" id="table-inactive-patients"></tbody>
                </table>
            </div>
        </div>
    </section>

    <!-- PROTOCOLOS -->
    <section class="hidden gap-section" id="protocolos">
        <div class="flex justify-between items-center mb-6">
            <div>
                <h3 class="font-heading font-bold text-lg text-[#6F4B36]">Gestão de Protocolos</h3>
                <p class="font-body text-sm text-gray-500">Defina os pacotes de serviços</p>
            </div>
            <button class="btn-primary" onclick="openModal('modal-novo-protocolo')">
                <i class="fa-solid fa-plus mr-2"></i>Novo Protocolo
            </button>
        </div>
        <div class="table-container">
            <table class="w-full text-sm">
                <thead>
                    <tr>
                        <th class="text-left">Nome</th>
                        <th class="text-left">Serviços</th>
                        <th class="text-right">Valor</th>
                        <th class="text-center">Duração</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-[#CBE5F7] divide-opacity-30" id="table-protocolos-body"></tbody>
            </table>
        </div>
    </section>

    <!-- AGENDA -->
    <section class="hidden gap-section" id="agenda">
        <div class="flex justify-between items-center mb-6">
            <div class="flex items-center gap-4">
                <h3 class="font-heading font-bold text-xl text-[#6F4B36]" id="calendar-month-year"></h3>
                <div class="flex gap-2">
                    <button class="btn-secondary !px-3 !py-2" onclick="changeMonth(-1)">
                        <i class="fa-solid fa-chevron-left"></i>
                    </button>
                    <button class="btn-secondary !px-4 !py-2" onclick="goToToday()">Hoje</button>
                    <button class="btn-secondary !px-3 !py-2" onclick="changeMonth(1)">
                        <i class="fa-solid fa-chevron-right"></i>
                    </button>
                </div>
            </div>
            <button class="btn-primary" onclick="openModal('modal-agendamento')">
                <i class="fa-solid fa-plus mr-2"></i>Novo Agendamento
            </button>
        </div>

        <div class="card p-6 mb-6">
            <div class="calendar-header">
                <div>DOM</div>
                <div>SEG</div>
                <div>TER</div>
                <div>QUA</div>
                <div>QUI</div>
                <div>SEX</div>
                <div>SÁB</div>
            </div>
            <div class="calendar-grid" id="calendar-grid"></div>
        </div>

        <div class="card p-6">
            <h3 class="font-heading font-bold text-lg text-[#6F4B36] mb-4 flex items-center gap-2">
                <i class="fa-solid fa-user-clock"></i>
                Fila de Espera / Check-in
            </h3>
            <div class="flex flex-wrap gap-4 min-h-[50px]" id="fila-espera-list"></div>
        </div>
    </section>

    <!-- ESTRATÉGIA -->
    <section class="hidden gap-section" id="estrategia">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
            <div class="card p-6">
                <h3 class="font-heading font-bold text-lg text-[#6F4B36] mb-4">Balancete Anual</h3>
                <div class="h-64 relative">
                    <canvas id="chart-financeiro-anual"></canvas>
                </div>
            </div>
            <div class="card p-6">
                <h3 class="font-heading font-bold text-lg text-[#6F4B36] mb-4">Crescimento de Pacientes</h3>
                <div class="h-64 relative">
                    <canvas id="chart-pacientes-anual"></canvas>
                </div>
            </div>
        </div>
        
        <div class="card p-6">
            <div class="flex justify-between items-center mb-6">
                <h3 class="font-heading font-bold text-lg text-[#6F4B36]">DRE Simplificado</h3>
                <button class="btn-secondary" onclick="window.print()">
                    <i class="fa-solid fa-print mr-2"></i>Imprimir
                </button>
            </div>
            <table class="w-full text-sm">
                <thead>
                    <tr>
                        <th class="text-left">Ano</th>
                        <th class="text-right text-[#6F4B36]">Receita</th>
                        <th class="text-right text-gray-600">Custos</th>
                        <th class="text-right text-green-600">Margem</th>
                        <th class="text-center">Novos Pacientes</th>
                        <th class="text-center">Ticket Médio</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-[#CBE5F7] divide-opacity-30 font-mono" id="table-estrategia-body"></tbody>
            </table>
        </div>
    </section>

    <!-- PACIENTES -->
    <section class="hidden gap-section" id="pacientes">
        <div class="flex gap-4 mb-6 no-print">
            <div class="relative flex-1">
                <i class="fa-solid fa-search absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
                <input class="w-full pl-10 pr-4 py-3 rounded-2xl border border-[#CBE5F7] focus:border-[#6F4B36] focus:ring-2 focus:ring-[#6F4B36] focus:ring-opacity-20" 
                       id="search-paciente" 
                       oninput="renderPacientes()" 
                       placeholder="Pesquisar pacientes..."/>
            </div>
            <button class="btn-primary" onclick="openModal('modal-paciente')">
                <i class="fa-solid fa-plus mr-2"></i>Novo Paciente
            </button>
        </div>
        
        <div class="table-container">
            <table class="w-full text-sm">
                <thead>
                    <tr>
                        <th class="text-left">Nome</th>
                        <th class="text-left">CPF</th>
                        <th class="text-left">Nascimento</th>
                        <th class="text-left">Tipo</th>
                        <th class="text-center">Cadastro</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-[#CBE5F7] divide-opacity-30" id="table-pacientes-body"></tbody>
            </table>
        </div>
    </section>

    <!-- ATENDIMENTO -->
    <section class="hidden gap-section" id="atendimento">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-1">
                <div class="card p-6">
                    <h3 class="font-heading font-bold text-lg text-[#6F4B36] mb-4 flex items-center gap-2">
                        <i class="fa-solid fa-users-between-lines"></i>
                        Fila de Atendimento
                    </h3>
                    <div class="space-y-3" id="today-appointments-list"></div>
                </div>
            </div>
            
            <div class="lg:col-span-2">
                <div class="card p-6">
                    <!-- Estado Vazio -->
                    <div class="h-64 flex flex-col items-center justify-center text-gray-400" id="area-clinica-empty">
                        <div class="w-20 h-20 bg-[#FCF7F9] rounded-full flex items-center justify-center mb-4">
                            <i class="fa-solid fa-user-doctor text-3xl text-[#6F4B36] opacity-30"></i>
                        </div>
                        <p class="font-body text-gray-500">Selecione um paciente para iniciar o atendimento</p>
                    </div>
                    
                    <!-- Estado Ativo -->
                    <div class="hidden" id="area-clinica-active">
                        <!-- Header do Paciente -->
                        <div class="flex justify-between items-start border-b border-[#CBE5F7] pb-6 mb-6">
                            <div>
                                <h4 class="font-heading text-2xl font-bold text-[#6F4B36]" id="current-patient-name"></h4>
                                <div class="flex items-center gap-3 mt-2">
                                    <span class="font-body text-sm text-gray-500">
                                        <i class="fa-regular fa-id-card mr-1"></i>
                                        <span id="current-patient-cpf"></span>
                                    </span>
                                    <span class="badge badge-secondary" id="atendimento-prioridade-badge"></span>
                                </div>
                            </div>
                            <div class="text-right">
                                <div class="badge badge-primary mb-2" id="atendimento-tipo"></div>
                                <div class="font-heading font-bold text-xl text-[#6F4B36]">
                                    <span id="atendimento-valor">R$ 0,00</span>
                                </div>
                            </div>
                        </div>

                        <!-- Anamnese -->
                        <div class="mb-8 bg-[#FCF7F9] rounded-2xl p-5 border border-[#CBE5F7] border-opacity-30">
                            <div class="flex justify-between items-center mb-3">
                                <h5 class="font-heading font-bold text-[#6F4B36] flex items-center gap-2">
                                    <i class="fa-solid fa-clipboard-user"></i>
                                    Anamnese
                                </h5>
                                <button class="btn-secondary !py-2 !px-4 text-sm" onclick="openQuestionnaire()">
                                    <i class="fa-solid fa-pen mr-2"></i>Preencher
                                </button>
                            </div>
                            <div class="font-body text-sm text-gray-600 bg-white p-4 rounded-xl border border-[#CBE5F7] border-opacity-30 min-h-[60px]" id="anamnese-preview">
                                Nenhum registro de anamnese.
                            </div>
                        </div>

                        <!-- Histórico Recente -->
                        <div class="mb-8">
                            <h5 class="font-heading font-bold text-[#6F4B36] mb-3 flex items-center gap-2">
                                <i class="fa-solid fa-clock-rotate-left"></i>
                                Histórico Recente
                            </h5>
                            <div class="space-y-2 max-h-40 overflow-y-auto pr-2" id="historico-recente-list"></div>
                        </div>

                        <!-- Prescrição -->
                        <div class="mb-8">
                            <h5 class="font-heading font-bold text-[#6F4B36] mb-3 flex items-center gap-2">
                                <i class="fa-solid fa-prescription"></i>
                                Prescrição
                            </h5>
                            <div class="flex gap-3 mb-3">
                                <select class="flex-1" id="consult-medication">
                                    <option value="">Selecione um medicamento...</option>
                                </select>
                                <input class="w-24 text-center" id="consult-qty" type="number" value="1" min="1"/>
                                <button class="btn-primary !px-4 !py-2" onclick="addMedicationToPrescription()">
                                    <i class="fa-solid fa-plus"></i>
                                </button>
                            </div>
                            <div class="bg-[#FCF7F9] p-4 rounded-xl border border-[#CBE5F7] border-opacity-30 text-sm" id="prescription-list"></div>
                        </div>

                        <!-- Exames -->
                        <div class="mb-8">
                            <h5 class="font-heading font-bold text-[#6F4B36] mb-3 flex items-center gap-2">
                                <i class="fa-solid fa-flask"></i>
                                Exames
                            </h5>
                            <div class="flex gap-3 mb-3">
                                <select class="flex-1" id="consult-exam">
                                    <option value="">Selecione um exame...</option>
                                </select>
                                <button class="btn-secondary !px-4 !py-2" onclick="addExamToConsultation()">
                                    <i class="fa-solid fa-plus"></i> Adicionar
                                </button>
                            </div>
                            <div class="bg-[#FCF7F9] p-4 rounded-xl border border-[#CBE5F7] border-opacity-30 text-sm" id="exams-list"></div>
                        </div>

                        <!-- Totais e Finalização -->
                        <div class="bg-[#FCF7F9] rounded-2xl p-6 mt-6 border border-[#CBE5F7] border-opacity-30">
                            <div class="space-y-2 mb-4">
                                <div class="flex justify-between text-sm">
                                    <span class="text-gray-600">Medicamentos:</span>
                                    <span class="font-mono font-bold" id="total-meds">R$ 0,00</span>
                                </div>
                                <div class="flex justify-between text-sm">
                                    <span class="text-gray-600">Exames:</span>
                                    <span class="font-mono font-bold" id="total-exams">R$ 0,00</span>
                                </div>
                                <div class="flex justify-between font-heading font-bold text-lg pt-3 mt-2 border-t border-[#CBE5F7]">
                                    <span class="text-[#6F4B36]">Total:</span>
                                    <span class="text-[#6F4B36]" id="total-final">R$ 0,00</span>
                                </div>
                            </div>
                            <button class="btn-primary w-full" id="btn-finalizar-pagar" onclick="proceedToPayment()">
                                <i class="fa-solid fa-check-circle mr-2"></i>Finalizar e Pagar
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ESTOQUE -->
    <section class="hidden gap-section" id="estoque">
        <div class="flex gap-4 mb-6 no-print">
            <div class="relative flex-1">
                <i class="fa-solid fa-search absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
                <input class="w-full pl-10 pr-4 py-3 rounded-2xl border border-[#CBE5F7] focus:border-[#6F4B36] focus:ring-2 focus:ring-[#6F4B36] focus:ring-opacity-20" 
                       id="search-estoque" 
                       oninput="renderEstoque()" 
                       placeholder="Pesquisar no estoque..."/>
            </div>
            <button class="btn-primary" onclick="openModal('modal-estoque')">
                <i class="fa-solid fa-boxes mr-2"></i>Adicionar Lote
            </button>
        </div>
        
        <div class="table-container">
            <table class="w-full text-sm">
                <thead>
                    <tr>
                        <th class="text-left">Nome</th>
                        <th class="text-left">Lote</th>
                        <th class="text-left">Validade</th>
                        <th class="text-center">Qtd</th>
                        <th class="text-right">Custo</th>
                        <th class="text-right">Venda</th>
                        <th class="text-center">Status</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-[#CBE5F7] divide-opacity-30" id="table-estoque-body"></tbody>
            </table>
        </div>
    </section>

    <!-- FINANCEIRO -->
    <section class="hidden gap-section" id="financeiro">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4 mb-6 no-print">
            <div>
                <h3 class="font-heading font-bold text-lg text-[#6F4B36]">Financeiro</h3>
                <p class="font-body text-sm text-gray-500">Controle receitas, despesas, pendências e exporte o relatório do período.</p>
            </div>
            <div class="flex flex-wrap gap-3">
                <button class="btn-primary" onclick="openFinancialModal()">
                    <i class="fa-solid fa-plus mr-2"></i>Novo lançamento
                </button>
                <button class="btn-secondary" onclick="exportFinancialExcel()">
                    <i class="fa-regular fa-file-excel mr-2"></i>Excel
                </button>
                <button class="btn-secondary" onclick="exportFinancialPDF()">
                    <i class="fa-regular fa-file-pdf mr-2"></i>PDF
                </button>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4 mb-6" id="financial-summary-cards">
            <div class="card p-5">
                <div class="text-xs uppercase tracking-wide text-gray-500">Receitas</div>
